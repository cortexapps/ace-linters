{
    "name": "@fmt/dart-fmt",
    "description": "Dart Formatter powered by WASM ported from dart_style",
    "author": "magic-akari <akari.ccino@gmail.com>",
    "version": "0.2.0",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/wasm-fmt/dart_fmt"
    },
    "module": "dart_fmt.js",
    "homepage": "https://github.com/wasm-fmt/dart_fmt",
    "types": "dart_fmt.d.ts",
    "keywords": [
        "wasm",
        "formatter",
        "dart"
    ],
    "main": "dart_fmt.js",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "exports": "./dart_fmt.js",
    "exclude": [
        "!../build",
        "*.tgz",
        ".npmignore"
    ]
}