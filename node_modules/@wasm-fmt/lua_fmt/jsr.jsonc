{
    "name": "@fmt/lua-fmt",
    "type": "module",
    "collaborators": [
        "magic-akari <akari.ccino@gmail.com>"
    ],
    "description": "A WASM based Lua Formatter",
    "version": "0.1.0",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/wasm-fmt/lua_fmt"
    },
    "homepage": "https://github.com/wasm-fmt/lua_fmt",
    "types": "lua_fmt.d.ts",
    "sideEffects": [
        "./snippets/*"
    ],
    "keywords": [
        "wasm",
        "stylua",
        "lua",
        "formatter"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": "./lua_fmt.js",
    "exclude": [
        "!**",
        "*.tgz"
    ]
}