{
    "name": "@wasm-fmt/lua_fmt",
    "type": "module",
    "collaborators": [
        "magic-akari <akari.ccino@gmail.com>"
    ],
    "description": "A WASM based Lua Formatter",
    "version": "0.1.0",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/wasm-fmt/lua_fmt"
    },
    "homepage": "https://github.com/wasm-fmt/lua_fmt",
    "types": "lua_fmt.d.ts",
    "sideEffects": [
        "./snippets/*"
    ],
    "keywords": [
        "wasm",
        "stylua",
        "lua",
        "formatter"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./lua_fmt.d.ts",
            "node": "./lua_fmt_node.js",
            "default": "./lua_fmt.js"
        },
        "./vite": {
            "types": "./lua_fmt.d.ts",
            "default": "./lua_fmt_vite.js"
        },
        "./package.json": "./package.json",
        "./*": "./*"
    }
}